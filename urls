const handleCheckboxChange = (module: string, action: string) => {
    setSelectedPermissions((prev) => {
        const modulePermissions = prev[module] || [];

        let updatedModulePermissions;

        if (modulePermissions.includes(action)) {
            // remove
            updatedModulePermissions = modulePermissions.filter((a) => a !== action);
        } else {
            // add
            updatedModulePermissions = [...modulePermissions, action];
        }

        let updatedPermissions = {
            ...prev,
            [module]: updatedModulePermissions,
        };

        // 🔥 Dependency Logic
        if (module === "user" && action === "create") {
            if (!modulePermissions.includes("create")) {
                // when selecting user:create → force role:list
                updatedPermissions["role"] = [
                    ...(updatedPermissions["role"] || []),
                    "list",
                ];
            } else {
                // when unselecting user:create → allow role:list removal
                updatedPermissions["role"] =
                    updatedPermissions["role"]?.filter((a) => a !== "list") || [];
            }
        }

        return updatedPermissions;
    });
};


<input
    type='checkbox'
    checked={selectedPermissions[module]?.includes(action) || false}
    onChange={() => handleCheckboxChange(module, action)}
    disabled={
        module === "role" &&
        action === "list" &&
        selectedPermissions["user"]?.includes("create")
    }
/>



const isDependencyActive = (module: string, action: string) => {
    return Object.entries(permissionDependencies).some(
        ([key, deps]) => {
            const [depModule, depAction] = key.split(":");

            return (
                selectedPermissions[depModule]?.includes(depAction) &&
                deps.some(
                    (d) => d.module === module && d.action === action
                )
            );
        }
    );
};


const applyDependencies = (
    permissions: Record<string, string[]>,
    module: string,
    action: string
) => {
    const key = `${module}:${action}`;
    const deps = permissionDependencies[key];

    if (!deps) return permissions;

    let updated = { ...permissions };

    deps.forEach(({ module: depModule, action: depAction }) => {
        const existing = updated[depModule] || [];

        if (!existing.includes(depAction)) {
            updated[depModule] = [...existing, depAction];

            // 🔥 recursive dependency support
            updated = applyDependencies(updated, depModule, depAction);
        }
    });

    return updated;
};


